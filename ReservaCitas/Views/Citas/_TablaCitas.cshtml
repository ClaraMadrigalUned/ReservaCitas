@model List<ReservaCitas.Models.Cita>

@if (Model.Count == 0)
{
    <p>No hay citas registradas.</p>
}
else
{
    <table class="table table-bordered">
        <tr>
            <th>Cliente</th>
            <th>Servicio</th>
            <th>Fecha</th>
            <th>Hora</th>
            <th>Estado</th>
            <th>Acción</th>
        </tr>

        @foreach (var cita in Model)
        {
            <tr>
                <td>@cita.NombreCliente</td>
                <td>@cita.Servicio</td>
                <td>@cita.Fecha.ToShortDateString()</td>
                <td>@cita.Hora.ToShortTimeString()</td>
                <td>@cita.Estado</td>
                <td>
                    @Html.ActionLink("Ver detalle", "Details", "Citas", new { id = cita.Id }, new { @class = "btn btn-info btn-sm" })
                </td>
            </tr>
        }
    </table>
}